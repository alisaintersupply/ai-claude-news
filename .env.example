# ============================================================
# ข่าว AI Claudecode — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — get these from your Supabase project dashboard
# Settings > API > Project URL and API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to browser, server-side only
# Settings > API > service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
